{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"],
      "@quanqn/schemas": ["../../packages/schemas/src"],
      "@quanqn/schemas/*": ["../../packages/schemas/src/*"],
      "@quanqn/ui": ["../../packages/ui/src"],
      "@quanqn/ui/*": ["../../packages/ui/src/*"],
      "@quanqn/clients": ["../../packages/clients/src"],
      "@quanqn/clients/*": ["../../packages/clients/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
