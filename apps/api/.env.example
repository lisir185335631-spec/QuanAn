# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://return@localhost:5432/quanqn
DATABASE_URL_TEST=postgresql://return@localhost:5432/quanqn_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Admin OAuth ───────────────────────────────────────────────────────────────
# 'mock' = dev mode (no password) · 'google' = Google Workspace (prod)
OAUTH_PROVIDER=mock

# ── Admin IP Whitelist (US-003) ───────────────────────────────────────────────
# Set to 'true' to enable CIDR-based IP restriction for all admin procedures
ADMIN_IP_WHITELIST_ENABLED=false
# Comma-separated CIDR list — only evaluated when ADMIN_IP_WHITELIST_ENABLED=true
ADMIN_IP_WHITELIST_CIDRS=10.0.0.0/8,192.168.0.0/16

# ── Admin MFA (US-003) ────────────────────────────────────────────────────────
# Set to 'true' to require super_admin to re-verify MFA every 30 days
ADMIN_MFA_REQUIRED=false

# ── DingTalk Webhook Notifications (US-015) ───────────────────────────────────
# Set to 'true' to enable real DingTalk webhook delivery (default: mock mode)
# When DINGTALK_ENABLE=true, DINGTALK_WEBHOOK_URL must be set (fail-fast on startup)
DINGTALK_ENABLE=false
# DingTalk robot webhook URL — only required when DINGTALK_ENABLE=true
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxx
