# QuanQn · 环境变量模板
#
# 复制本文件为 .env 并填入真实值。.env 已 gitignore · 不要提交。
# 生产环境用 Vercel / Railway / Supabase 的 Secret Manager。

# ============================================================
# 基础
# ============================================================
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ============================================================
# 数据库(Supabase 或自建 Postgres)
# ============================================================
DATABASE_URL=postgresql://user:pass@localhost:5432/quanqn
DIRECT_URL=postgresql://user:pass@localhost:5432/quanqn  # Prisma 直连(供 migration 用)
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/quanqn_test

# Redis(Upstash 或自建)
REDIS_URL=redis://localhost:6379

# S3 / OSS
S3_BUCKET=quanqn-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============================================================
# AI 模型(LLMGateway 透明降级 · 详 ADR-013)
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-key-here-replace-me  # REQUIRED · 必填
OPENAI_API_KEY=sk-...                                  # REQUIRED for IMAGE_GEN_ENABLED=true · DALL-E 3 image generation

# ImageGen Worker(PRD-6 · D-038)
# IMAGE_GEN_ENABLED=false   → placeholder URL · 无 OpenAI 调用(dev default)
# IMAGE_GEN_ENABLED=true    → 真调 DALL-E 3 · 需 OPENAI_API_KEY
IMAGE_GEN_ENABLED=false

# 国内备选(可选)
ALIYUN_API_KEY=
TENCENT_API_KEY=

# ============================================================
# OAuth(REQUIRED for prod · dev 可暂跳过)
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URL=http://localhost:5173/auth/callback

# Session
SESSION_SECRET=please-change-this-to-random-string-32-chars-min   # REQUIRED · 必填(生产用 openssl rand -hex 32)

# ============================================================
# Trending 抓取(LD-017 · 选第三方授权)
# ============================================================
TRENDING_VENDOR=xinbang        # xinbang | cmm | feigua | official(待 API 接通)
TRENDING_API_KEY=
TRENDING_FETCH_INTERVAL_HOURS=4

# ============================================================
# 监控 / Analytics
# ============================================================
PLAUSIBLE_DOMAIN=
SENTRY_DSN=

# ============================================================
# Coding 3.0(开发期)
# ============================================================
RALPH_MODEL=sonnet
OPUS_AUDIT_ENABLED=true
